# T-Claw local runtime environment
# Copy to .env and set real values.

# Telegram bot
TELEGRAM_TOKEN=
TELEGRAM_ENABLED=true
# Comma-separated Telegram user IDs or usernames. Leave blank for open access.
TELEGRAM_ALLOW_FROM=

# Hub mode: default skill + two specialist profiles
MOFACLAW_AGENTS_DEFAULT_SKILL=skills/hub.md
MOFACLAW_AGENTS_SUBAGENTS_JSON=[{"id":"mofa-specialist","skill":"skills/agent_mofa.md"},{"id":"security-specialist","skill":"skills/agent_tclaw.md"}]

# Trust layer (TEA/TSP)
MOFACLAW_TRUST_ENABLED=true
MOFACLAW_TRUST_ALLOW_UNSIGNED_INBOUND=true
MOFACLAW_TRUST_SIGNING_VID_PATH=/absolute/path/to/local_signing_vid.json
MOFACLAW_TRUST_VERIFY_VID_PATH=/absolute/path/to/peer_or_local_verify_vid.json
MOFACLAW_TRUST_STRICT_INBOUND_CHANNELS=system
